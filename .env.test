# Test Environment Settings

# Database settings
TEST_DATABASE_URL=sqlite:///./test.db
TEST_DATABASE_ECHO=false

# Redis settings
TEST_REDIS_URL=redis://localhost:6379/1
TEST_REDIS_PREFIX=test:

# JWT settings
TEST_JWT_SECRET=test_secret_key
TEST_JWT_ALGORITHM=HS256
TEST_JWT_EXPIRE_MINUTES=30

# Telegram settings
TEST_TELEGRAM_BOT_TOKEN=test_bot_token
TEST_TELEGRAM_WEBHOOK_URL=http://localhost:8000/webhook

# Payment settings
TEST_PAYMENT_API_KEY=test_payment_key
TEST_PAYMENT_WEBHOOK_URL=http://localhost:8000/payment/webhook

# 3x-UI Panel settings
TEST_PANEL_URL=http://localhost:8080
TEST_PANEL_USERNAME=test_admin
TEST_PANEL_PASSWORD=test_password

# Test user settings
TEST_USER_PHONE=+989123456789
TEST_USER_PASSWORD=test_password123
TEST_USER_EMAIL=test@example.com

# Test admin settings
TEST_ADMIN_PHONE=+989123456790
TEST_ADMIN_PASSWORD=admin_password123
TEST_ADMIN_EMAIL=admin@example.com

# Test server settings
TEST_SERVER_HOST=test.vpn.example.com
TEST_SERVER_PORT=443
TEST_SERVER_PROTOCOL=tls

# Test settings
TESTING=true
LOG_LEVEL=DEBUG
ENVIRONMENT=test 