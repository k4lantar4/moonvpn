# Environment variables for MoonVPN 🌙

# --- General Settings / تنظیمات عمومی ---
ENVIRONMENT=development # development, testing, production / محیط اجرایی
SECRET_KEY=your_very_secret_key_here # Change this in production! / کلید رمزنگاری - حتما در محیط پروداکشن تغییر دهید
LOG_LEVEL=INFO # DEBUG, INFO, WARNING, ERROR, CRITICAL / سطح لاگ‌گیری

# --- Database (MySQL) / پایگاه داده ---
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=moonvpn_user
MYSQL_PASSWORD=your_strong_db_password
MYSQL_DATABASE=moonvpn_db
MYSQL_ROOT_PASSWORD=your_strong_root_password
# SQLAlchemy Database URL (constructed from above variables)
# DATABASE_URL=mysql+mysqlconnector://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DATABASE}

# --- Redis Cache / ردیس کش ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD= # Uncomment and set if Redis requires password / در صورت نیاز به رمز عبور برای ردیس
REDIS_SSL=False # Enable for production with SSL / برای استفاده از SSL در محیط پروداکشن
REDIS_MAX_CONNECTIONS=10 # Maximum number of connections in the pool / حداکثر تعداد اتصالات همزمان

# --- API Server (FastAPI/Uvicorn) / سرور API ---
API_HOST=0.0.0.0
API_PORT=8000
WORKERS_COUNT=1 # Number of uvicorn workers / تعداد ورکرهای یوویکورن
CORS_ORIGINS=["http://localhost:3000"] # Allowed CORS origins / دامنه‌های مجاز برای CORS
RATE_LIMIT_PER_MINUTE=60 # API rate limiting / محدودیت تعداد درخواست در دقیقه

# --- Telegram Bot / ربات تلگرام ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here # Get from @BotFather / از @BotFather دریافت کنید
TELEGRAM_ADMIN_ID=your_telegram_user_id # Your Telegram user ID / شناسه تلگرام شما
TELEGRAM_WEBHOOK_URL= # Set in production (e.g., https://yourdomain.com/api/v1/bot/webhook)
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_token # Required for webhook security / کلید امنیتی وبهوک

# --- Telegram Channels / کانال‌های تلگرام ---
# Get these IDs from @username_to_id_bot / شناسه‌ها را از @username_to_id_bot دریافت کنید
ADMIN_CHANNEL_ID= # Channel for admin notifications / کانال اعلان‌های مدیریت
PAYMENT_CHANNEL_ID= # Channel for payment verifications / کانال تایید پرداخت‌ها
REPORT_CHANNEL_ID= # Channel for system reports / کانال گزارش‌های سیستم
LOG_CHANNEL_ID= # Channel for system logs / کانال لاگ‌های سیستم
ALERT_CHANNEL_ID= # Channel for urgent alerts / کانال هشدارهای فوری
BACKUP_CHANNEL_ID= # Channel for backups / کانال پشتیبان‌گیری

# --- 3x-ui Panel Settings / تنظیمات پنل ---
# Add more numbered panels as needed / در صورت نیاز پنل‌های بیشتری اضافه کنید
PANEL1_URL=http://your-panel-domain.com:2053
PANEL1_USERNAME=your_panel_username
PANEL1_PASSWORD=your_panel_password
PANEL1_LOCATION=🇩🇪 Germany # Use country flag emoji / از ایموجی پرچم کشور استفاده کنید

# --- Payment Gateway / درگاه پرداخت ---
ZARINPAL_MERCHANT_ID= # Your ZarinPal merchant ID / شناسه درگاه زرین‌پال
ZARINPAL_SANDBOX=True # Set to False for production / در محیط پروداکشن False قرار دهید

# --- SMS Service (Future) / سرویس پیامک ---
SMS_API_KEY= # SMS provider API key / کلید API سرویس پیامک
SMS_SENDER= # SMS sender number / شماره فرستنده پیامک
SMS_TEMPLATE_VERIFICATION= # SMS template for verification / قالب پیامک تایید

# --- Docker & Tools / داکر و ابزارها ---
PHPMYADMIN_PORT=8080 # phpMyAdmin web interface port / پورت رابط وب phpMyAdmin
PROMETHEUS_PORT=9090 # Prometheus metrics port / پورت پرومتئوس
GRAFANA_PORT=3000 # Grafana dashboard port / پورت گرافانا

# --- Security & JWT / امنیت و توکن ---
ACCESS_TOKEN_EXPIRE_MINUTES=30 # JWT access token expiry / مدت اعتبار توکن دسترسی
REFRESH_TOKEN_EXPIRE_DAYS=7 # JWT refresh token expiry / مدت اعتبار توکن تازه‌سازی
ALGORITHM=HS256 # JWT signing algorithm / الگوریتم امضای توکن
PASSWORD_SALT= # Salt for password hashing / نمک برای هش کردن رمز عبور

# --- System Limits / محدودیت‌های سیستم ---
MAX_CLIENTS_PER_PANEL=500 # Maximum clients per panel / حداکثر تعداد کاربر در هر پنل
MAX_DAILY_TRIALS=50 # Maximum daily trial accounts / حداکثر اکانت تست روزانه
DEFAULT_TRAFFIC_LIMIT=100 # Default traffic limit in GB / محدودیت ترافیک پیش‌فرض به گیگابایت
